#!/usr/bin/env php
<?php

declare(strict_types=1);

$autoload = dirname(__DIR__) . '/vendor/autoload.php';
if (!is_file($autoload)) {
    fwrite(STDERR, "Run composer install first.\n");
    exit(1);
}
require $autoload;

$argv = $_SERVER['argv'] ?? [];
array_shift($argv);
$cmd = $argv[0] ?? '';
array_shift($argv);

if ($cmd === '' || $cmd === 'help' || $cmd === '--help' || $cmd === '-h') {
    echo "Usage: block2docs <command> [args...]\n\nCommands:\n  parse\n  generate-docs\n";
    exit($cmd === '' ? 1 : 0);
}

if ($cmd === 'parse') {
    (new Block2Docs\Command\ParseCommand())->execute($argv);
    exit(0);
}

if ($cmd === 'generate-docs' || $cmd === 'docs') {
    (new Block2Docs\Command\GenerateDocsCommand())->execute($argv);
    exit(0);
}

fwrite(STDERR, "Unknown command: {$cmd}\n");
exit(1);

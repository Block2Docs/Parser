    "url": "https://github.com/Block2Docs/Parser/issues"
  },
  "homepage": "https://github.com/Block2Docs/Parser#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3"
  }
}
